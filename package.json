{
  "name": "infinite-canvas-claude",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "concurrently -k -n web,mcp -c blue,magenta \"npm run dev -w web\" \"npm run dev -w mcp\"",
    "dev:web": "npm run dev -w web",
    "dev:mcp": "npm run dev -w mcp",
    "dev:agent": "npm run dev -w agent"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
